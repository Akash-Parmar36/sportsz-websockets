{
  "middleware": [
    {
      "name": "json",
      "enabled": true,
      "options": {
        "limit": "10mb"
      }
    },
    {
      "name": "urlencoded",
      "enabled": true,
      "options": {
        "extended": true,
        "limit": "10mb"
      }
    },
    {
      "name": "cors",
      "enabled": false,
      "options": {}
    }
  ],
  "server": {
    "port": 3000,
    "host": "localhost"
  }
}
